# Trading Intelligence System — Environment Variables
# Copy to .env and fill in values

# Supabase (new project — create at supabase.com)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Polygon.io (free tier — sign up at polygon.io)
POLYGON_API_KEY=your-polygon-api-key

# FRED (free — no key needed for basic use, but sign up for higher limits)
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# AI Analysis (Phase 2)
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
